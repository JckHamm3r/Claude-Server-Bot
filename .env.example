# Claude Server Bot — Environment Configuration
# Copy to .env and fill in your values

# ─── Core ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Authentication ──────────────────────────────────────────────────────
# Full URL including the path prefix and slug, used by NextAuth for callback URLs
# Format: https://yourdomain.com/<bot-name>/<random-slug>
NEXTAUTH_URL=http://localhost:3000/your-bot-name/your-slug
# Secret for signing JWTs — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ─── Bot Identity ────────────────────────────────────────────────────────
# URL path prefix derived from bot name (lowercase, alphanumeric + hyphens)
# e.g. bot name "Jarvis" → prefix "jarvis" → URL: /jarvis/<slug>
CLAUDE_BOT_PATH_PREFIX=your-bot-name
NEXT_PUBLIC_CLAUDE_BOT_PATH_PREFIX=your-bot-name
# Random URL slug for routing (e.g. "a8Bx3kQ9m2pR")
CLAUDE_BOT_SLUG=your-slug
NEXT_PUBLIC_CLAUDE_BOT_SLUG=your-slug
# Display name shown in the UI
CLAUDE_BOT_NAME=Claude-Bot
# Admin login email
CLAUDE_BOT_ADMIN_EMAIL=admin@example.com
# bcrypt hash of the admin password — generate with: node -e "console.log(require('bcryptjs').hashSync('password', 12))"
CLAUDE_BOT_ADMIN_HASH=bcrypt-hash-here

# ─── Anthropic ────────────────────────────────────────────────────────────
# API key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Working directory that Claude operates in
CLAUDE_PROJECT_ROOT=/home/user/project

# ─── Data ────────────────────────────────────────────────────────────────
# Directory for SQLite database and other persistent data
DATA_DIR=./data
